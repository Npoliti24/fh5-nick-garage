function scoreDots(score) {
  let h = '<div class="score-dots">';
  for (let i = 1; i <= 3; i++) h += `<div class="score-dot ${i <= score ? 'on' : 'off'}"></div>`;
  return h + '</div>';
}

function parseCodes(str) {
  return str.split(/[|,]/).map(c => c.trim()).filter(Boolean);
}

function copyCode(code, btn) {
  navigator.clipboard.writeText(code).then(() => {
    btn.textContent = 'COPIED!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'COPY'; btn.classList.remove('copied'); }, 1500);
  }).catch(() => { btn.textContent = 'ERR'; setTimeout(() => { btn.textContent = 'COPY'; }, 1500); });
}

function renderCard(car) {
  const codes = (car.code && car.code.trim()) ? parseCodes(car.code) : [];
  const notesParts = car.notes ? car.notes.split('|') : [];
  const codesHtml = codes.length === 0
    ? '<div class="tune-code-row"><span style="font-family:var(--font-mono);font-size:11px;color:var(--text-faint);font-style:italic;">// no tune code listed</span></div>'
    : codes.map((c, i) => {
    const label = codes.length > 1 && notesParts[i] ? `<span class="tune-code-label">${notesParts[i].trim()}</span>` : '';
    return `<div class="tune-code-row">
      <span class="tune-code">${c}</span>
      ${label}
      <button class="copy-btn" onclick="copyCode('${c}', this)">COPY</button>
    </div>`;
  }).join('');
  const notesHtml = car.notes && codes.length === 1 ? `<div class="tune-notes">${car.notes}</div>` : '';
  return `<div class="tune-card">
    <div class="tune-card-top">
      <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap">
        <span class="tune-car-name">${car.car}</span>
        <span class="tune-brand">${car.brand}</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        ${scoreDots(car.score)}
        <span class="tune-class-badge badge-${car.class}">${car.class}</span>
      </div>
    </div>
    <div class="tune-meta">
      ${car.race ? `<span class="tune-meta-pill">${car.race}</span>` : ''}
      ${car.build ? `<span class="tune-meta-pill">${car.build}</span>` : ''}
      ${car.best ? `<span class="tune-meta-pill">${car.best}</span>` : ''}
    </div>
    <div class="tune-codes">${codes.length === 0 ? '<div class="tune-code-row"><span style="font-family:var(--font-mono);font-size:11px;color:var(--text-faint);font-style:italic;">// no tune code listed</span></div>' : codesHtml}</div>
    ${notesHtml}
  </div>`;
}

function filterTunes() {
  const query = document.getElementById('tuneSearch').value.toLowerCase().trim();
  const cls = document.getElementById('filterClass').value;
  const race = document.getElementById('filterRace').value;
  const score = document.getElementById('filterScore').value;
  const resultsEl = document.getElementById('tuneResults');
  const listEl = document.getElementById('tuneList');
  const countEl = document.getElementById('tuneCount');

  if (!query && !cls && !race && !score) { resultsEl.classList.remove('visible'); return; }

  let filtered = GARAGE_DB.filter(car => {
    if (cls && car.class !== cls) return false;
    if (race && !car.race.toLowerCase().includes(race.toLowerCase())) return false;
    if (score && car.score < parseInt(score)) return false;
    if (query) {
      const hay = `${car.car || ''} ${car.brand || ''} ${car.build || ''} ${car.best || ''} ${car.notes || ''}`.toLowerCase();
      if (!hay.includes(query)) return false;
    }
    return true;
  });

  resultsEl.classList.add('visible');
  countEl.textContent = `${filtered.length} result${filtered.length !== 1 ? 's' : ''}`;

  if (!filtered.length) { listEl.innerHTML = '<div class="no-results">// no matches found</div>'; return; }

  const shown = filtered.slice(0, 50);
  listEl.innerHTML = shown.map(renderCard).join('');
  if (filtered.length > 50) {
    listEl.innerHTML += `<div class="no-results">// showing 50 of ${filtered.length} — refine to narrow down</div>`;
  }
}

// ── TRAINING PANEL ────────────────────────────────────────────────────────

// localStorage keys
const LS_TUNES = 'ncf_custom_tunes';
const LS_CONTEXT = 'ncf_ai_context';

// Load persisted state
let customTunes = [];
try { customTunes = JSON.parse(localStorage.getItem(LS_TUNES) || '[]'); } catch(e) {}

function setTrainTab(tab) {
  document.querySelectorAll('.train-tab').forEach((b, i) => b.classList.toggle('active', (i === 0 && tab === 'tune') || (i === 1 && tab === 'context')));
  document.getElementById('trainTunePanel').classList.toggle('active', tab === 'tune');
  document.getElementById('trainContextPanel').classList.toggle('active', tab === 'context');
}

function parsetuneEntry(raw) {
  // Accept: "Car Name, Class, tune: 123 456 789 | 987 654 321"
  // Also: "Car Name, Class, 123 456 789"
  const line = raw.trim();
  if (!line) return null;
  const tuneMatch = line.match(/^(.+?),\s*([A-Za-z0-9/]+),\s*(?:tune:\s*)?([\d\s|,]+)$/i);
  if (!tuneMatch) return null;
  const car = tuneMatch[1].trim();
  const cls = tuneMatch[2].trim().toUpperCase();
  const codes = tuneMatch[3].split(/[|,]/).map(c => c.trim().replace(/\s+/g,' ')).filter(c => /^\d{3} \d{3} \d{3}$/.test(c) || /^\d{9}$/.test(c));
  if (!car || !codes.length) return null;
  // Normalise 9-digit codes to XXX XXX XXX format
  const normCodes = codes.map(c => c.replace(/\s/g,'').replace(/(\d{3})(\d{3})(\d{3})/, '$1 $2 $3'));
  return { car, class: cls, code: normCodes.join(' | '), score: 3, brand: '', race: '', build: 'Custom', best: 'Custom entry', notes: 'Custom tune', custom: true };
}

function addCustomTune() {
  const raw = document.getElementById('tuneAddInput').value;
  const fb = document.getElementById('tuneFeedback');
  const lines = raw.split('\n').filter(l => l.trim());
  if (!lines.length) { fb.textContent = '// nothing to parse'; fb.className = 'train-feedback error'; return; }

  let added = 0, failed = 0;
  for (const line of lines) {
    const entry = parsetuneEntry(line);
    if (entry) {
      customTunes.push(entry);
      added++;
    } else {
      failed++;
    }
  }

  if (added) {
    localStorage.setItem(LS_TUNES, JSON.stringify(customTunes));
    document.getElementById('tuneAddInput').value = '';
    fb.textContent = `// added ${added} entr${added > 1 ? 'ies' : 'y'}${failed ? ` — ${failed} line(s) couldn't be parsed` : ''}`;
    fb.className = 'train-feedback';
    renderCustomEntries();
    rebuildCustomAc();
  } else {
    fb.textContent = `// couldn't parse — use format: Car, Class, tune: 123 456 789`;
    fb.className = 'train-feedback error';
  }
}

function removeCustomTune(idx) {
  customTunes.splice(idx, 1);
  localStorage.setItem(LS_TUNES, JSON.stringify(customTunes));
  renderCustomEntries();
  rebuildCustomAc();
}

function clearCustomTunes() {
  if (!customTunes.length) return;
  customTunes = [];
  localStorage.removeItem(LS_TUNES);
  renderCustomEntries();
  rebuildCustomAc();
  const fb = document.getElementById('tuneFeedback');
  fb.textContent = '// cleared';
  fb.className = 'train-feedback';
}

function renderCustomEntries() {
  const el = document.getElementById('customEntriesList');
  if (!customTunes.length) { el.innerHTML = ''; return; }
  el.innerHTML = customTunes.map((t, i) => `
    <div class="custom-entry">
      <span class="custom-entry-info">${t.car} <span style="color:var(--text-faint)">${t.class}</span></span>
      <span class="custom-entry-code">${t.code}</span>
      <button class="btn-remove" onclick="removeCustomTune(${i})" title="Remove">×</button>
    </div>`).join('');
}

// AI Context
function saveAiContext() {
  const val = document.getElementById('aiContextInput').value;
  localStorage.setItem(LS_CONTEXT, val);
  const status = document.getElementById('contextStatus');
  if (val.trim()) {
    status.textContent = `// saved — ${val.trim().split('\n').filter(Boolean).length} line(s) will be appended to every AI query`;
    status.className = 'context-status active';
  } else {
    status.textContent = '// empty — no extra context will be sent';
    status.className = 'context-status';
  }
}

function getAiContext() {
  return (localStorage.getItem(LS_CONTEXT) || '').trim();
}

// filterTunes — merges GARAGE_DB with custom tunes
function filterTunes() {
  // Merge GARAGE_DB with customTunes before filtering
  const query = document.getElementById('tuneSearch').value.toLowerCase().trim();
  const cls = document.getElementById('filterClass').value;
  const race = document.getElementById('filterRace').value;
  const score = document.getElementById('filterScore').value;
  const resultsEl = document.getElementById('tuneResults');
  const listEl = document.getElementById('tuneList');
  const countEl = document.getElementById('tuneCount');

  if (!query && !cls && !race && !score) { resultsEl.classList.remove('visible'); return; }

  const combined = [...GARAGE_DB, ...customTunes];
  let filtered = combined.filter(car => {
    if (cls && car.class !== cls) return false;
    if (race && !car.race.toLowerCase().includes(race.toLowerCase())) return false;
    if (score && car.score < parseInt(score)) return false;
    if (query) {
      const hay = `${car.car || ''} ${car.brand || ''} ${car.build || ''} ${car.best || ''} ${car.notes || ''}`.toLowerCase();
      if (!hay.includes(query)) return false;
    }
    return true;
  });

  resultsEl.classList.add('visible');
  const customCount = filtered.filter(c => c.custom).length;
  countEl.textContent = `${filtered.length} result${filtered.length !== 1 ? 's' : ''}${customCount ? ` (${customCount} custom)` : ''}`;

  if (!filtered.length) { listEl.innerHTML = '<div class="no-results">// no matches found</div>'; return; }

  const shown = filtered.slice(0, 50);
  listEl.innerHTML = shown.map(renderCard).join('');
  if (filtered.length > 50) {
    listEl.innerHTML += `<div class="no-results">// showing 50 of ${filtered.length} — refine to narrow down</div>`;
  }
}

// Custom AC entries derived from customTunes
let customAcEntries = [];
function rebuildCustomAc() {
  customAcEntries = customTunes.map(t => ({
    name: t.car + (t.class ? ' (' + t.class + ')' : ''),
    brand: '',
    car: t.car,
    class: t.class,
    race: t.race || '',
    score: 3,
    backstage: false,
    hasCode: true,
    custom: true
  }));
}

// Init on load
document.addEventListener('DOMContentLoaded', () => {
  updateApiKeyUi();
  rebuildCustomAc();
  renderCustomEntries();
  const saved = localStorage.getItem(LS_CONTEXT) || '';
  if (saved) {
    document.getElementById('aiContextInput').value = saved;
    saveAiContext();
  }
});

// ── API KEY MANAGEMENT ──────────────────────────────────────────────────────
const LS_API_KEY = 'ncf_api_key';

function getApiKey() {
  return localStorage.getItem(LS_API_KEY) || '';
}

function saveApiKey() {
  const val = document.getElementById('apiKeyInput').value.trim();
  if (!val.startsWith('sk-ant-')) {
    document.getElementById('apiKeyInput').style.borderColor = '#f43f5e';
    setTimeout(() => document.getElementById('apiKeyInput').style.borderColor = '', 1500);
    return;
  }
  localStorage.setItem(LS_API_KEY, val);
  document.getElementById('apiKeyInput').value = '';
  updateApiKeyUi();
}

function clearApiKey() {
  localStorage.removeItem(LS_API_KEY);
  updateApiKeyUi();
}

function updateApiKeyUi() {
  const key = getApiKey();
  const banner = document.getElementById('apiBanner');
  const label = document.getElementById('apiLabel');
  const clearBtn = document.getElementById('clearKeyBtn');
  const input = document.getElementById('apiKeyInput');
  if (key) {
    banner.classList.add('connected');
    label.textContent = '✓ API Key connected';
    input.placeholder = '••••••••••••••••••••••' + key.slice(-4);
    clearBtn.style.display = 'inline-block';
  } else {
    banner.classList.remove('connected');
    label.textContent = 'API Key';
    input.placeholder = 'Paste your Anthropic API key — sk-ant-...';
    clearBtn.style.display = 'none';
  }
}

