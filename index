// ── MODE TOGGLE ────────────────────────────────────────────────────────────
let currentMode = 'race';
function setMode(mode) {
  currentMode = mode;
  document.getElementById('modeRace').classList.toggle('active', mode === 'race');
  document.getElementById('modeCar').classList.toggle('active', mode === 'car');
  document.getElementById('carFirstPanel').style.display = mode === 'car' ? 'block' : 'none';
  document.getElementById('raceFirstPanel').style.display = mode === 'race' ? 'block' : 'none';
  document.getElementById('outputSection').classList.remove('visible');
  if (mode === 'car') setTimeout(() => document.getElementById('carSearchInput').focus(), 50);
}

// ── AUTOCOMPLETE ───────────────────────────────────────────────────────────
let dropdownFocusIdx = -1;

function onCarSearch(val) {
  const drop = document.getElementById('carDropdown');
  const q = val.trim().toLowerCase();
  if (!q) { drop.classList.remove('open'); return; }
  const allAcCars = [...GARAGE_CARS, ...customAcEntries];
  const matches = allAcCars.filter(c => c.name.toLowerCase().includes(q)).slice(0, 10);
  if (!matches.length) { drop.classList.remove('open'); return; }
  dropdownFocusIdx = -1;
  const esc = s => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  drop.innerHTML = matches.map((c, i) => {
    const hi = c.name.replace(new RegExp(`(${esc(q)})`, 'gi'), '<mark>$1</mark>');
    const bc = c.backstage ? 'backstage' : c.score >= 4 ? 'tier3' : '';
    const bt = c.backstage ? 'BACKSTAGE' : c.score >= 4 ? 'FAVE ★' : c.hasCode ? 'OWNED' : 'OWNED — no code';
    return `<div class="car-option" data-name="${c.name}" data-idx="${i}" onmousedown="selectCar('${c.name.replace(/'/g,"\\'")}')">
      <span class="car-option-name">${hi}</span>
      <span class="car-option-meta">
        <span class="car-badge">${c.class}</span>
        <span class="car-badge ${bc}">${bt}</span>
      </span>
    </div>`;
  }).join('');
  drop.classList.add('open');
}

function selectCar(name) {
  document.getElementById('carSearchInput').value = name;
  document.getElementById('carDropdown').classList.remove('open');
}

function onCarSearchKey(e) {
  const drop = document.getElementById('carDropdown');
  const items = drop.querySelectorAll('.car-option');
  if (!drop.classList.contains('open')) return;
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    dropdownFocusIdx = Math.min(dropdownFocusIdx + 1, items.length - 1);
    items.forEach((el, i) => el.classList.toggle('focused', i === dropdownFocusIdx));
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    dropdownFocusIdx = Math.max(dropdownFocusIdx - 1, 0);
    items.forEach((el, i) => el.classList.toggle('focused', i === dropdownFocusIdx));
  } else if (e.key === 'Enter' && dropdownFocusIdx >= 0) {
    e.preventDefault();
    selectCar(items[dropdownFocusIdx].dataset.name);
  } else if (e.key === 'Escape') {
    drop.classList.remove('open');
  }
}

document.addEventListener('click', e => {
  if (!e.target.closest('.car-search-wrap')) {
    document.getElementById('carDropdown')?.classList.remove('open');
  }
});

// ── SHARED STREAM HELPER ───────────────────────────────────────────────────
async function streamResponse(messages, systemExtra = '') {
  const outputText = document.getElementById('outputText');
  const cursor = document.getElementById('cursor');
  const section = document.getElementById('outputSection');
  section.classList.add('visible');
  outputText.textContent = '';
  cursor.style.display = 'inline-block';
  section.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

  // Inject persisted AI context if present
  const _ctx = (localStorage.getItem('ncf_ai_context') || '').trim();
  const _fullExtra = [systemExtra, _ctx ? "NICK'S CURRENT NOTES / NEW INFO:\n" + _ctx : ''].filter(Boolean).join('\n\n');

  const _apiKey = getApiKey();
  if (!_apiKey) {
    document.getElementById('apiKeyInput').focus();
    document.getElementById('apiBanner').style.boxShadow = '0 0 0 2px #f43f5e';
    setTimeout(() => document.getElementById('apiBanner').style.boxShadow = '', 2000);
    throw new Error('No API key set');
  }
  const response = await fetch('https://corsproxy.io/?url=https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': _apiKey,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-allow-browser': 'true'
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      system: SYSTEM_PROMPT + (_fullExtra ? '\n\n' + _fullExtra : ''),
      stream: true,
      messages
    })
  });

  const reader = response.body.getReader();
  const decoder = new TextDecoder();
  let buffer = '';
  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    buffer += decoder.decode(value, { stream: true });
    const lines = buffer.split('\n');
    buffer = lines.pop();
    for (const line of lines) {
      if (!line.startsWith('data: ')) continue;
      const data = line.slice(6).trim();
      if (data === '[DONE]') continue;
      try {
        const parsed = JSON.parse(data);
        if (parsed.type === 'content_block_delta' && parsed.delta?.text) {
          outputText.textContent += parsed.delta.text;
        }
      } catch(e) {}
    }
  }
  cursor.style.display = 'none';
}

